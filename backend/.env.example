# Core
NODE_ENV=development
HOST=0.0.0.0
PORT=3010

# JWT
JWT_SECRET=replace-with-64-char-hex-secret-minimum-32-chars-required-here
JWT_EXPIRY=24h

# Auth
AUTH_MODE=local

# Database
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5434
DB_NAME=nebula_hosting
DB_USER=nebula
DB_PASSWORD=change-me
DB_POOL_MAX=20
DB_POOL_MIN=2

# Redis
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# Proxmox (noeud par défaut — d'autres noeuds s'ajoutent via l'admin)
PROXMOX_DEFAULT_NODE=pve1
PROXMOX_HOST=192.168.1.10
PROXMOX_PORT=8006
PROXMOX_USER=root@pam
PROXMOX_TOKEN_ID=nebula@pam!hosting
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_VERIFY_SSL=false
PROXMOX_STORAGE=local
PROXMOX_BRIDGE=vmbr0
PROXMOX_VMID_START=200

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend URL (pour Stripe redirects)
FRONTEND_URL=http://localhost:3011

# Email (optionnel)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@nebulahosting.example
SMTP_FROM_NAME=NebulaHosting

# CORS
ALLOWED_ORIGINS=http://localhost:3011,http://localhost:5173

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIMEWINDOW=60000

# Security
CSRF_ENABLED=false
LOG_LEVEL=info
